# ─────────────────────────────────────────────────────────────────────────────
# Store Rating Platform — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (Docker Compose):
DATABASE_URL="postgresql://postgres:password@localhost:5432/store_rating_db?schema=public"
# Production (Render): Use the Internal Database URL from your Render PostgreSQL dashboard.
# Example: DATABASE_URL="postgresql://user:pass@dpg-xxxxx-a.oregon-postgres.render.com/store_rating_db"

# ── JWT Authentication ────────────────────────────────────────────────────────
# IMPORTANT: In production, use a cryptographically strong random string (min 32 chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-key-change-in-production"
JWT_EXPIRATION="24h"

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Render sets PORT automatically; do NOT hardcode it in the Render dashboard.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local development:
CORS_ORIGIN="http://localhost:5173"
# Production (Vercel): Set this to your exact Vercel frontend URL.
# Example: CORS_ORIGIN="https://store-rating-platform.vercel.app"
