# ─────────────────────────────────────────────────────────────────────────────
# Store Rating Platform — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# Local development:
VITE_API_BASE_URL=http://localhost:3000/api
# Production (Render backend): Set this to your Render backend web service URL.
# Example: VITE_API_BASE_URL=https://store-rating-backend.onrender.com/api

# ── App Branding ──────────────────────────────────────────────────────────────
VITE_APP_NAME=Store Rating Platform
