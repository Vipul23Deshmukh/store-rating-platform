				{
					"name": "User Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.accessToken) {",
									"    pm.globals.set(\"token\", jsonData.accessToken);",
									"    pm.globals.set(\"role\", \"ADMIN\");",
									"    console.log(\"Token extracted and set as global variable for ADMIN\");",
